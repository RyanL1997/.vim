# Default theme — tracked here so new machines pick it up automatically.
# Browse alternatives with `ghostty +list-themes`.
theme = Citruszest

# Cursor — must come after `theme`, which sets a dim #666666 that's hard to
# spot. Matched to Citruszest's foreground so the cursor never outshines the
# text; the old iTerm2 #d0d0d0 was tuned for a pure black background.
cursor-color = #bfbfbf
cursor-text = #ffffff
cursor-style = block
cursor-style-blink = true

# Ghostty's shell integration owns the cursor shape by default (it forces a
# bar at the prompt), which silently overrides cursor-style above. Turn that
# feature off so cursor-style actually applies.
shell-integration-features = no-cursor

# Per-machine override (optional — `?` skips silently if absent).
# `ghostty +list-themes` → `w` writes the selected theme here, and because
# this include comes last, it wins over the default above.
config-file = ?auto/theme.ghostty
